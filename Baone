RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not hum or not hrp then return end
    if Flags.Speed then hum.WalkSpeed = Flags.SpeedVal end
    if Flags.WalkOnWater then
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and (v.Name:lower():find("water") or v.Name:lower():find("ocean") or v.Name:lower():find("sea")) then
                v.CanCollide = false
            end
        end
    end
    if Flags.KillAura then
        pcall(function()
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
                    if obj ~= char and obj.Humanoid.Health > 0 then
                        local dist = (obj.HumanoidRootPart.Position - hrp.Position).Magnitude
                        if dist < 15 then
                            local tool = char:FindFirstChildWhichIsA("Tool")
                            if tool then
                                local remote = tool:FindFirstChildWhichIsA("RemoteEvent")
                                if remote then pcall(function() remote:FireServer(obj.HumanoidRootPart.CFrame) end) end
                            end
                        end
                    end
                end
            end
        end)
    end
    if Flags.AutoBlock then
        pcall(function()
            local rs = game:GetService("ReplicatedStorage")
            local remote = rs:FindFirstChild("Remotes") and rs.Remotes:FindFirstChild("CommF_")
            if remote then remote:InvokeServer("Block") end
        end)
    end
    if Flags.AutoObservation then
        pcall(function()
            local rs = game:GetService("ReplicatedStorage")
            local remote = rs:FindFirstChild("Remotes") and rs.Remotes:FindFirstChild("CommF_")
            if remote then remote:InvokeServer("Observation") end
        end)
    end
end)

RunService.Stepped:Connect(function()
